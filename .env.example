# Neon (Postgres) 接続文字列。
# Neon コンソール → Connect → Connection string（HTTP経由の drizzle-orm/neon-http を
# 使うため、pooled connection の文字列で問題ない）をそのまま貼り付ける。
# 例: postgresql://<user>:<password>@<host>.neon.tech/<database>?sslmode=require
DATABASE_URL=

# Clerk（認証・組織・ロール）。Clerk Dashboard → API Keys から取得する。
# 事前に Organizations を有効化し（Membership required）、Roles & Permissions で
# 組織作成者に自動付与される Creator role を「Owner」（org:owner）に設定しておくこと
# （Clerk標準は Admin/Member の2段階のみのため、Owner/Admin/Memberの3段階にするには
# カスタムロールの追加が必要。詳細はセクション3の実装メモを参照）。
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# `npm run db:seed` の投入先組織ID（Clerk Organizations の org_xxx）。
# 実際にアプリで組織を作成した後、Clerk Dashboard の Organizations 一覧等で確認する。
SEED_ORG_ID=

# 会員承認制（プラットフォーム管理者専用ページ）。
# サービス運営者のメールアドレスをカンマ区切りで列挙する。ここに列挙したメールアドレスの
# ユーザーは、承認状態（pending/rejected）に関わらず常にアプリを利用でき、/admin
# （承認待ちユーザーの承認・却下ページ）にアクセスできる。
PLATFORM_ADMIN_EMAILS=

# 課題提出・デモ確認用。既定では承認制を有効にする。
# Vercel の提出用URLで「承認待ち」の人にも確認してもらいたい場合だけ false にする。
# サインインと組織所属チェックは維持される。
APPROVAL_REQUIRED=true

# AI実接続（Vercel AI SDK）。
# BYOK方針のため、AI APIキー自体はここに置かない（ユーザーごとにアプリ内の
# 「Gemini APIキー設定」ダイアログから登録し、Clerkユーザーのprivate metadataに保存する）。
# 現在実装済みの provider は gemini。将来別 provider を足す場合は lib/ai/model.ts に集約する。
AI_PROVIDER=gemini
AI_MODEL_ID=

# 後方互換用。未設定なら AI_MODEL_ID → GEMINI_MODEL_ID → 既定値の順で解決する。
GEMINI_MODEL_ID=
